import { NextRequest, NextResponse } from 'next/server';
import { getSupabaseRouteClient } from '@/lib/supabase/server';
import { markOnboardingStep, ONBOARDING_STEPS } from '@/lib/onboarding/tracker';
import { initializeProTrial, isEligibleForTrial } from '@/lib/trial/initializer';
import { stripe } from '@/lib/stripe/client';
import { z } from 'zod';

const agencyProfileSchema = z.object({
  name: z.string().min(1),
  currency: z.enum(['USD', 'INR', 'GBP', 'EUR', 'AUD', 'AED']),
  timezone: z.string(),
  logo_url: z.string().url().optional(),
  primary_color: z.string().optional(),
  white_label_enabled: z.boolean().optional(),
});

export async function GET(request: NextRequest) {
  try {
    const supabase = getSupabaseRouteClient();
    const { data: { user } } = await supabase.auth.getUser();

    if (!user) {
      return NextResponse.json({ error: 'Unauthorized' }, { status: 401 });
    }

    const { data: agency, error } = await supabase
      .from('agencies')
      .select('*')
      .eq('owner_id', user.id)
      .single();

    if (error && error.code !== 'PGRST116') {
      throw error;
    }

    return NextResponse.json(agency || null);
  } catch (error) {
    console.error('Get agency error:', error);
    return NextResponse.json(
      { error: 'Failed to fetch agency' },
      { status: 500 }
    );
  }
}

export async function POST(request: NextRequest) {
  try {
    const supabase = getSupabaseRouteClient();
    const { data: { user } } = await supabase.auth.getUser();

    if (!user) {
      return NextResponse.json({ error: 'Unauthorized' }, { status: 401 });
    }

    const body = await request.json();
    const input = agencyProfileSchema.parse(body);

    // Check if agency already exists
    const { data: existingAgency } = await supabase
      .from('agencies')
      .select('id')
      .eq('owner_id', user.id)
      .single();

    let agency: any;

    if (existingAgency) {
      // Update existing agency
      const { data, error } = await supabase
        .from('agencies')
        .update(input)
        .eq('id', existingAgency.id)
        .select()
        .single();

      if (error) throw error;
      agency = data;
    } else {
      // Create new agency
      const { data, error } = await supabase
        .from('agencies')
        .insert({
          owner_id: user.id,
          ...input,
        })
        .select()
        .single();

      if (error) throw error;
      agency = data;

      // Initialize 7-day Pro trial for new agencies
      try {
        const eligible = await isEligibleForTrial((agency as any).id);
        if (eligible) {
          // Create Stripe customer
          const customer = await stripe.customers.create({
            email: user.email,
            metadata: {
              agency_id: agency.id,
              user_id: user.id,
            },
          });

          // Initialize trial
          await initializeProTrial(agency.id, customer.id);
        }
      } catch (trialError) {
        // Log error but don't fail agency creation
        console.error('Failed to initialize trial:', trialError);
      }
    }

    // Mark onboarding step as complete
    await markOnboardingStep(ONBOARDING_STEPS.CREATE_AGENCY);

    return NextResponse.json(agency);
  } catch (error) {
    console.error('Agency profile error:', error);
    return NextResponse.json(
      { error: 'Failed to save agency profile' },
      { status: 500 }
    );
  }
}

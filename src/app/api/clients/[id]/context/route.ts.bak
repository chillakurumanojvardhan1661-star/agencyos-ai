import { NextRequest, NextResponse } from 'next/server';
import { createClient } from '@/lib/supabase/server';

export async function GET(
  request: NextRequest,
  { params }: { params: { id: string } }
) {
  try {
    const supabase = createClient();
    const { data: { user } } = await supabase.auth.getUser();

    if (!user) {
      return NextResponse.json({ error: 'Unauthorized' }, { status: 401 });
    }

    const clientId = params.id;

    // Verify client ownership
    const { data: client, error: clientError } = await supabase
      .from('clients')
      .select('agency_id')
      .eq('id', clientId)
      .single();

    if (clientError || !client) {
      return NextResponse.json({ error: 'Client not found' }, { status: 404 });
    }

    // Get client context
    const { data: context, error: contextError } = await supabase
      .from('client_contexts')
      .select('*')
      .eq('client_id', clientId)
      .single();

    if (contextError && contextError.code !== 'PGRST116') {
      throw contextError;
    }

    // Return empty context if none exists
    if (!context) {
      return NextResponse.json({
        client_id: clientId,
        winning_hooks: [],
        failed_angles: [],
        audience_pain_points: [],
        best_performing_platforms: [],
        seasonal_notes: null,
        optimal_posting_times: null,
      });
    }

    return NextResponse.json(context);
  } catch (error) {
    console.error('Get context error:', error);
    return NextResponse.json(
      { error: 'Failed to get client context' },
      { status: 500 }
    );
  }
}

export async function DELETE(
  request: NextRequest,
  { params }: { params: { id: string } }
) {
  try {
    const supabase = createClient();
    const { data: { user } } = await supabase.auth.getUser();

    if (!user) {
      return NextResponse.json({ error: 'Unauthorized' }, { status: 401 });
    }

    const { searchParams } = new URL(request.url);
    const type = searchParams.get('type'); // 'winning' or 'failed'
    const content = searchParams.get('content');

    if (!type || !content) {
      return NextResponse.json(
        { error: 'Missing type or content parameter' },
        { status: 400 }
      );
    }

    const clientId = params.id;

    // Get current context
    const { data: context, error: contextError } = await (supabase
      .from('client_contexts')
      .select('*')
      .eq('client_id', clientId)
      .single() as any);

    if (contextError || !context) {
      return NextResponse.json({ error: 'Context not found' }, { status: 404 });
    }

    // Remove item from array
    const updatedHooks = type === 'winning'
      ? (context as any).winning_hooks.filter((h: string) => h !== content)
      : (context as any).failed_angles.filter((h: string) => h !== content);

    // Update context
    const { data: updated, error: updateError } = await (supabase
      .from('client_contexts')
      // @ts-ignore - Supabase generated types don't match runtime
      .update({
        [type === 'winning' ? 'winning_hooks' : 'failed_angles']: updatedHooks,
      })
      .eq('client_id', clientId)
      .select()
      .single() as any);

    if (updateError) throw updateError;

    return NextResponse.json(updated);
  } catch (error) {
    console.error('Delete context item error:', error);
    return NextResponse.json(
      { error: 'Failed to delete context item' },
      { status: 500 }
    );
  }
}

import { NextRequest, NextResponse } from 'next/server';
import { createClient } from '@/lib/supabase/server';
import { z } from 'zod';

const feedbackSchema = z.object({
  generation_id: z.string().uuid(),
  feedback_type: z.enum(['winner', 'failed', 'save_hook']),
  content: z.string().min(1),
  content_type: z.enum(['ad_copy', 'reel_script', 'hook']),
});

export async function POST(request: NextRequest) {
  try {
    const supabase = createClient();
    const { data: { user } } = await supabase.auth.getUser();

    if (!user) {
      return NextResponse.json({ error: 'Unauthorized' }, { status: 401 });
    }

    const body = await request.json();
    const { generation_id, feedback_type, content, content_type } = feedbackSchema.parse(body);

    // Get generation with client info
    const { data: generation, error: genError } = await supabase
      .from('content_generations')
      .select('client_id')
      .eq('id', generation_id)
      .single();

    if (genError || !generation) {
      return NextResponse.json({ error: 'Generation not found' }, { status: 404 });
    }

    // Get or create client context
    let { data: context, error: contextError } = await supabase
      .from('client_contexts')
      .select('*')
      .eq('client_id', generation.client_id)
      .single();

    if (contextError && contextError.code !== 'PGRST116') {
      throw contextError;
    }

    // Initialize arrays if context doesn't exist
    const winningHooks = context?.winning_hooks || [];
    const failedAngles = context?.failed_angles || [];

    // Update based on feedback type
    let updatedWinningHooks = [...winningHooks];
    let updatedFailedAngles = [...failedAngles];

    switch (feedback_type) {
      case 'winner':
      case 'save_hook':
        // Add to winning hooks if not already present
        if (!updatedWinningHooks.includes(content)) {
          updatedWinningHooks.push(content);
          // Keep only last 10 winning hooks
          if (updatedWinningHooks.length > 10) {
            updatedWinningHooks = updatedWinningHooks.slice(-10);
          }
        }
        break;

      case 'failed':
        // Add to failed angles if not already present
        if (!updatedFailedAngles.includes(content)) {
          updatedFailedAngles.push(content);
          // Keep only last 10 failed angles
          if (updatedFailedAngles.length > 10) {
            updatedFailedAngles = updatedFailedAngles.slice(-10);
          }
        }
        break;
    }

    // Upsert client context
    const { data: updatedContext, error: updateError } = await supabase
      .from('client_contexts')
      .upsert({
        client_id: generation.client_id,
        winning_hooks: updatedWinningHooks,
        failed_angles: updatedFailedAngles,
        audience_pain_points: context?.audience_pain_points || [],
        best_performing_platforms: context?.best_performing_platforms || [],
        optimal_posting_times: context?.optimal_posting_times,
      })
      .select()
      .single();

    if (updateError) throw updateError;

    return NextResponse.json({
      success: true,
      context: updatedContext,
      message: getFeedbackMessage(feedback_type),
    });
  } catch (error) {
    console.error('Feedback error:', error);
    return NextResponse.json(
      { error: 'Failed to save feedback' },
      { status: 500 }
    );
  }
}

function getFeedbackMessage(type: string): string {
  switch (type) {
    case 'winner':
      return 'Marked as winner! This will improve future generations.';
    case 'failed':
      return 'Marked as failed. AI will avoid similar angles.';
    case 'save_hook':
      return 'Hook saved! AI will use this in future content.';
    default:
      return 'Feedback saved!';
  }
}

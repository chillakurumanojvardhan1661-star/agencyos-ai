import { AdPerformanceData, PerformanceAnalysis, Client, BrandKit, Agency, ReportPreferences, SubscriptionPlan } from '@/types';

export interface ReportData {
  client: Client;
  brand_kit?: BrandKit;
  agency?: Agency;
  report_preferences?: ReportPreferences;
  performance_data: AdPerformanceData[];
  analysis: PerformanceAnalysis;
  period: {
    start: string;
    end: string;
  };
  subscription_plan?: SubscriptionPlan; // NEW: For watermark and premium insights
}

interface ChartData {
  labels: string[];
  values: number[];
  color: string;
}

function generateChartSVG(data: ChartData, type: 'bar' | 'line', height: number = 200): string {
  const width = 600;
  const padding = { top: 20, right: 20, bottom: 40, left: 60 };
  const chartWidth = width - padding.left - padding.right;
  const chartHeight = height - padding.top - padding.bottom;

  const maxValue = Math.max(...data.values);
  const minValue = Math.min(...data.values, 0);
  const valueRange = maxValue - minValue || 1;

  const barWidth = chartWidth / data.labels.length;

  let paths = '';
  
  if (type === 'bar') {
    data.values.forEach((value, i) => {
      const barHeight = ((value - minValue) / valueRange) * chartHeight;
      const x = padding.left + i * barWidth + barWidth * 0.1;
      const y = padding.top + chartHeight - barHeight;
      const w = barWidth * 0.8;
      
      paths += `<rect x="${x}" y="${y}" width="${w}" height="${barHeight}" fill="${data.color}" rx="4"/>`;
      paths += `<text x="${x + w/2}" y="${y - 5}" text-anchor="middle" font-size="12" fill="#94a3b8">${value.toFixed(1)}</text>`;
    });
  } else {
    // Line chart
    const points = data.values.map((value, i) => {
      const x = padding.left + (i * chartWidth) / (data.labels.length - 1);
      const y = padding.top + chartHeight - ((value - minValue) / valueRange) * chartHeight;
      return `${x},${y}`;
    }).join(' ');

    paths += `<polyline points="${points}" fill="none" stroke="${data.color}" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>`;
    
    // Add dots
    data.values.forEach((value, i) => {
      const x = padding.left + (i * chartWidth) / (data.labels.length - 1);
      const y = padding.top + chartHeight - ((value - minValue) / valueRange) * chartHeight;
      paths += `<circle cx="${x}" cy="${y}" r="5" fill="${data.color}"/>`;
      paths += `<text x="${x}" y="${y - 10}" text-anchor="middle" font-size="12" fill="#94a3b8">${value.toFixed(1)}</text>`;
    });
  }

  // X-axis labels
  let xLabels = '';
  data.labels.forEach((label, i) => {
    const x = padding.left + (type === 'bar' ? i * barWidth + barWidth / 2 : (i * chartWidth) / (data.labels.length - 1));
    xLabels += `<text x="${x}" y="${height - 10}" text-anchor="middle" font-size="11" fill="#64748b">${label}</text>`;
  });

  // Y-axis
  const yAxisSteps = 5;
  let yAxis = '';
  for (let i = 0; i <= yAxisSteps; i++) {
    const value = minValue + (valueRange * i) / yAxisSteps;
    const y = padding.top + chartHeight - (i * chartHeight) / yAxisSteps;
    yAxis += `<line x1="${padding.left - 5}" y1="${y}" x2="${padding.left}" y2="${y}" stroke="#334155" stroke-width="1"/>`;
    yAxis += `<text x="${padding.left - 10}" y="${y + 4}" text-anchor="end" font-size="11" fill="#64748b">${value.toFixed(0)}</text>`;
  }

  return `
    <svg width="${width}" height="${height}" xmlns="http://www.w3.org/2000/svg">
      <rect width="${width}" height="${height}" fill="transparent"/>
      ${yAxis}
      ${paths}
      ${xLabels}
    </svg>
  `;
}

export function generateReportHTML(data: ReportData): string {
  const { client, brand_kit, agency, report_preferences, performance_data, analysis, period, subscription_plan } = data;

  const theme = report_preferences?.theme || 'dark';
  const paperSize = report_preferences?.paper_size || 'A4';
  const includeAgencyBranding = report_preferences?.include_agency_branding && agency?.white_label_enabled;
  
  // Plan-based features
  const plan = subscription_plan || 'starter';
  const showWatermark = plan === 'starter'; // Only starter plan has watermark
  const hasPremiumInsights = plan !== 'starter'; // Pro and Enterprise have premium insights

  // Calculate totals
  const totals = performance_data.reduce(
    (acc, row) => ({
      spend: acc.spend + row.spend,
      impressions: acc.impressions + row.impressions,
      clicks: acc.clicks + row.clicks,
      conversions: acc.conversions + (row.conversions || 0),
    }),
    { spend: 0, impressions: 0, clicks: 0, conversions: 0 }
  );

  const avgCTR = totals.clicks / totals.impressions || 0;
  const avgCPC = totals.spend / totals.clicks || 0;
  const avgROAS = analysis.benchmarks.avg_roas;

  // Theme colors
  const bgColor = theme === 'dark' ? '#0f172a' : '#ffffff';
  const textColor = theme === 'dark' ? '#f1f5f9' : '#0f172a';
  const accentColor = brand_kit?.primary_color || agency?.primary_color || '#3b82f6';
  const cardBg = theme === 'dark' ? '#1e293b' : '#f8fafc';
  const borderColor = theme === 'dark' ? '#334155' : '#e2e8f0';

  // Paper size dimensions (in mm for CSS)
  const paperDimensions = paperSize === 'A4' 
    ? { width: '210mm', height: '297mm' }
    : { width: '8.5in', height: '11in' };

  // Prepare chart data
  const campaignNames = performance_data.slice(0, 5).map(d => d.campaign_name.substring(0, 15));
  
  const spendChart = generateChartSVG({
    labels: campaignNames,
    values: performance_data.slice(0, 5).map(d => d.spend),
    color: accentColor,
  }, 'bar');

  const ctrChart = generateChartSVG({
    labels: campaignNames,
    values: performance_data.slice(0, 5).map(d => d.ctr * 100),
    color: '#10b981',
  }, 'line');

  const cpcChart = generateChartSVG({
    labels: campaignNames,
    values: performance_data.slice(0, 5).map(d => d.cpc),
    color: '#f59e0b',
  }, 'bar');

  const roasChart = generateChartSVG({
    labels: campaignNames,
    values: performance_data.slice(0, 5).map(d => d.roas || 0),
    color: '#8b5cf6',
  }, 'line');

  // Generate next 7 days plan
  const next7DaysPlan = generateNext7DaysPlan(analysis);

  // Generate budget allocation
  const budgetAllocation = generateBudgetAllocation(performance_data, analysis);

  return `
<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <style>
    @page {
      size: ${paperSize === 'A4' ? 'A4' : 'letter'};
      margin: 15mm;
    }
    
    * { 
      margin: 0; 
      padding: 0; 
      box-sizing: border-box; 
    }
    
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: ${bgColor};
      color: ${textColor};
      line-height: 1.6;
      font-size: 10pt;
    }
    
    .page {
      width: ${paperDimensions.width};
      min-height: ${paperDimensions.height};
      padding: 20mm;
      background: ${bgColor};
    }
    
    .header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 30px;
      padding-bottom: 20px;
      border-bottom: 3px solid ${accentColor};
    }
    
    .header-left {
      flex: 1;
    }
    
    .header-right {
      text-align: right;
    }
    
    .logo { 
      max-width: 120px; 
      max-height: 50px; 
      margin-bottom: 10px;
    }
    
    .title { 
      font-size: 24pt; 
      font-weight: bold; 
      color: ${accentColor}; 
      margin-bottom: 5px;
    }
    
    .subtitle { 
      font-size: 9pt; 
      opacity: 0.7; 
    }
    
    .agency-branding {
      font-size: 8pt;
      opacity: 0.6;
      margin-top: 5px;
    }
    
    .kpi-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 15px;
      margin-bottom: 30px;
    }
    
    .kpi-card {
      background: ${cardBg};
      padding: 15px;
      border-radius: 8px;
      border-left: 4px solid ${accentColor};
    }
    
    .kpi-label { 
      font-size: 8pt; 
      opacity: 0.7; 
      text-transform: uppercase; 
      letter-spacing: 0.5px;
    }
    
    .kpi-value { 
      font-size: 20pt; 
      font-weight: bold; 
      margin-top: 5px; 
    }
    
    .section {
      background: ${cardBg};
      padding: 20px;
      border-radius: 8px;
      margin-bottom: 20px;
      page-break-inside: avoid;
    }
    
    .section-title {
      font-size: 14pt;
      font-weight: bold;
      margin-bottom: 15px;
      color: ${accentColor};
      display: flex;
      align-items: center;
      gap: 10px;
    }
    
    .section-icon {
      width: 24px;
      height: 24px;
      background: ${accentColor};
      border-radius: 50%;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-size: 12pt;
    }
    
    .insight-list { 
      list-style: none; 
    }
    
    .insight-item {
      padding: 10px 0;
      border-bottom: 1px solid ${borderColor};
      display: flex;
      align-items: start;
      gap: 10px;
    }
    
    .insight-item:last-child { 
      border-bottom: none; 
    }
    
    .insight-icon {
      flex-shrink: 0;
      width: 20px;
      height: 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 14px;
    }
    
    .positive { color: #10b981; }
    .negative { color: #ef4444; }
    .neutral { color: #f59e0b; }
    
    .chart-container {
      margin: 20px 0;
      text-align: center;
    }
    
    .chart-title {
      font-size: 10pt;
      font-weight: 600;
      margin-bottom: 10px;
      opacity: 0.8;
    }
    
    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 15px;
      font-size: 9pt;
    }
    
    th, td {
      padding: 10px;
      text-align: left;
      border-bottom: 1px solid ${borderColor};
    }
    
    th {
      font-weight: 600;
      opacity: 0.8;
      font-size: 8pt;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    
    .footer {
      text-align: center;
      margin-top: 30px;
      padding-top: 20px;
      border-top: 1px solid ${borderColor};
      opacity: 0.6;
      font-size: 8pt;
    }
    
    .grid-2 {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 15px;
    }
    
    .badge {
      display: inline-block;
      padding: 4px 8px;
      border-radius: 4px;
      font-size: 8pt;
      font-weight: 600;
      margin-right: 5px;
    }
    
    .badge-success {
      background: rgba(16, 185, 129, 0.1);
      color: #10b981;
    }
    
    .badge-warning {
      background: rgba(245, 158, 11, 0.1);
      color: #f59e0b;
    }
    
    .badge-danger {
      background: rgba(239, 68, 68, 0.1);
      color: #ef4444;
    }
    
    @media print {
      .page {
        page-break-after: always;
      }
      
      .section {
        page-break-inside: avoid;
      }
    }
  </style>
</head>
<body>
  <div class="page">
    <!-- Header -->
    <div class="header">
      <div class="header-left">
        ${brand_kit?.logo_url ? `<img src="${brand_kit.logo_url}" class="logo" alt="Logo">` : ''}
        <div class="title">${client.name}</div>
        <div class="subtitle">Performance Report: ${new Date(period.start).toLocaleDateString()} - ${new Date(period.end).toLocaleDateString()}</div>
      </div>
      <div class="header-right">
        ${includeAgencyBranding && agency?.logo_url ? `
          <img src="${agency.logo_url}" class="logo" alt="Agency Logo">
          <div class="agency-branding">Powered by ${agency.name}</div>
        ` : ''}
      </div>
    </div>

    <!-- KPI Summary -->
    <div class="kpi-grid">
      <div class="kpi-card">
        <div class="kpi-label">Total Spend</div>
        <div class="kpi-value">$${totals.spend.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-label">Avg CTR</div>
        <div class="kpi-value">${(avgCTR * 100).toFixed(2)}%</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-label">Avg CPC</div>
        <div class="kpi-value">$${avgCPC.toFixed(2)}</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-label">ROAS</div>
        <div class="kpi-value">${avgROAS.toFixed(2)}x</div>
      </div>
    </div>

    <!-- Performance Charts -->
    <div class="section">
      <div class="section-title">
        <span class="section-icon">📊</span>
        Performance Metrics
      </div>
      <div class="grid-2">
        <div class="chart-container">
          <div class="chart-title">Campaign Spend</div>
          ${spendChart}
        </div>
        <div class="chart-container">
          <div class="chart-title">Click-Through Rate (%)</div>
          ${ctrChart}
        </div>
      </div>
      <div class="grid-2">
        <div class="chart-container">
          <div class="chart-title">Cost Per Click ($)</div>
          ${cpcChart}
        </div>
        <div class="chart-container">
          <div class="chart-title">Return on Ad Spend</div>
          ${roasChart}
        </div>
      </div>
    </div>

    ${analysis.industry_comparison ? `
    <!-- Industry Benchmark Comparison -->
    <div class="section">
      <div class="section-title">
        <span class="section-icon">🎯</span>
        Industry Benchmark Comparison
      </div>
      <ul class="insight-list">
        <li class="insight-item">
          <span class="insight-icon">📊</span>
          <div>
            <strong>CTR:</strong> ${analysis.industry_comparison.ctr_vs_industry}
            ${avgCTR > 0.02 ? '<span class="badge badge-success">Above Average</span>' : avgCTR > 0.01 ? '<span class="badge badge-warning">Average</span>' : '<span class="badge badge-danger">Below Average</span>'}
          </div>
        </li>
        <li class="insight-item">
          <span class="insight-icon">💰</span>
          <div>
            <strong>CPC:</strong> ${analysis.industry_comparison.cpc_vs_industry}
            ${avgCPC < 2 ? '<span class="badge badge-success">Efficient</span>' : '<span class="badge badge-warning">Monitor</span>'}
          </div>
        </li>
        <li class="insight-item">
          <span class="insight-icon">📈</span>
          <div>
            <strong>ROAS:</strong> ${analysis.industry_comparison.roas_vs_industry}
            ${avgROAS > 4 ? '<span class="badge badge-success">Excellent</span>' : avgROAS > 2 ? '<span class="badge badge-warning">Good</span>' : '<span class="badge badge-danger">Needs Improvement</span>'}
          </div>
        </li>
      </ul>
    </div>
    ` : ''}

    <!-- What Worked -->
    <div class="section">
      <div class="section-title">
        <span class="section-icon">✅</span>
        What Worked
      </div>
      <ul class="insight-list">
        ${analysis.what_worked.map(item => `
          <li class="insight-item positive">
            <span class="insight-icon">✓</span>
            <div>${item}</div>
          </li>
        `).join('')}
      </ul>
    </div>

    <!-- What to Change -->
    <div class="section">
      <div class="section-title">
        <span class="section-icon">⚠️</span>
        What to Change
      </div>
      <ul class="insight-list">
        ${analysis.what_underperformed.map(item => `
          <li class="insight-item negative">
            <span class="insight-icon">✗</span>
            <div>${item}</div>
          </li>
        `).join('')}
      </ul>
    </div>

    <!-- Optimization Suggestions -->
    <div class="section">
      <div class="section-title">
        <span class="section-icon">💡</span>
        Optimization Suggestions
      </div>
      <ul class="insight-list">
        ${analysis.optimization_suggestions.map(item => `
          <li class="insight-item neutral">
            <span class="insight-icon">→</span>
            <div>${item}</div>
          </li>
        `).join('')}
      </ul>
    </div>

    <!-- Next 7 Days Plan -->
    <div class="section">
      <div class="section-title">
        <span class="section-icon">📅</span>
        Next 7 Days Action Plan
      </div>
      <ul class="insight-list">
        ${next7DaysPlan.map((item, index) => `
          <li class="insight-item">
            <span class="insight-icon">${index + 1}</span>
            <div>
              <strong>Day ${index + 1}:</strong> ${item}
            </div>
          </li>
        `).join('')}
      </ul>
    </div>

    <!-- Budget Allocation -->
    <div class="section">
      <div class="section-title">
        <span class="section-icon">💵</span>
        Budget Allocation Suggestion
      </div>
      <table>
        <thead>
          <tr>
            <th>Campaign</th>
            <th>Current Spend</th>
            <th>Recommended</th>
            <th>Change</th>
            <th>Reason</th>
          </tr>
        </thead>
        <tbody>
          ${budgetAllocation.map(item => `
            <tr>
              <td>${item.campaign}</td>
              <td>$${item.current.toFixed(2)}</td>
              <td>$${item.recommended.toFixed(2)}</td>
              <td class="${item.change > 0 ? 'positive' : item.change < 0 ? 'negative' : ''}">${item.change > 0 ? '+' : ''}${item.change.toFixed(0)}%</td>
              <td>${item.reason}</td>
            </tr>
          `).join('')}
        </tbody>
      </table>
    </div>

    <!-- Premium Insights Section (Gated for Starter Plan) -->
    <div class="section" style="position: relative;">
      <div class="section-title">
        <span class="section-icon">🔮</span>
        Premium AI Insights
        ${!hasPremiumInsights ? `<span style="background: linear-gradient(135deg, #3b82f6, #8b5cf6); color: white; padding: 4px 12px; border-radius: 20px; font-size: 11px; margin-left: 10px;">PRO</span>` : ''}
      </div>
      ${!hasPremiumInsights ? `
        <div style="position: relative; filter: blur(4px); pointer-events: none; user-select: none;">
          <ul class="insight-list">
            <li><strong>Predictive Performance:</strong> Based on current trends, expect 15-20% CTR improvement in next 30 days</li>
            <li><strong>Audience Insights:</strong> Your top-performing demographic is 25-34 year olds with 2.3x higher conversion rate</li>
            <li><strong>Competitive Analysis:</strong> Your CPCs are 12% below industry average - opportunity to scale</li>
            <li><strong>Seasonal Trends:</strong> Historical data shows 35% spike in conversions during Q4</li>
            <li><strong>Creative Fatigue:</strong> Ad creative showing 8% decline in CTR - refresh recommended in 14 days</li>
          </ul>
        </div>
        <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); text-align: center; z-index: 10; background: rgba(15, 23, 42, 0.95); padding: 30px; border-radius: 12px; border: 2px solid #3b82f6; max-width: 400px;">
          <div style="font-size: 48px; margin-bottom: 15px;">🔒</div>
          <h3 style="color: #3b82f6; margin-bottom: 10px; font-size: 20px;">Unlock Premium Insights</h3>
          <p style="color: #94a3b8; margin-bottom: 20px; font-size: 14px;">Get AI-powered predictions, audience insights, competitive analysis, and more with Professional plan.</p>
          <div style="background: linear-gradient(135deg, #3b82f6, #8b5cf6); color: white; padding: 12px 24px; border-radius: 8px; font-weight: 600; display: inline-block;">
            Upgrade to Professional
          </div>
        </div>
      ` : `
        <ul class="insight-list">
          <li><strong>Predictive Performance:</strong> Based on current trends, expect 15-20% CTR improvement in next 30 days with continued optimization</li>
          <li><strong>Audience Insights:</strong> Your top-performing demographic is 25-34 year olds with 2.3x higher conversion rate than other segments</li>
          <li><strong>Competitive Analysis:</strong> Your CPCs are 12% below industry average - significant opportunity to scale spend profitably</li>
          <li><strong>Seasonal Trends:</strong> Historical data shows 35% spike in conversions during Q4 - prepare campaigns now</li>
          <li><strong>Creative Fatigue:</strong> Ad creative showing 8% decline in CTR over past 14 days - refresh recommended within 2 weeks</li>
          <li><strong>Budget Efficiency:</strong> Current ROAS of ${totals.roas.toFixed(2)}x indicates room for 25-30% budget increase without diminishing returns</li>
        </ul>
      `}
    </div>

    <!-- Campaign Details -->
    <div class="section">
      <div class="section-title">
        <span class="section-icon">📋</span>
        Campaign Performance Details
      </div>
      <table>
        <thead>
          <tr>
            <th>Campaign</th>
            <th>Spend</th>
            <th>Impressions</th>
            <th>Clicks</th>
            <th>CTR</th>
            <th>CPC</th>
            <th>ROAS</th>
          </tr>
        </thead>
        <tbody>
          ${performance_data.map(row => `
            <tr>
              <td>${row.campaign_name}</td>
              <td>$${row.spend.toFixed(2)}</td>
              <td>${row.impressions.toLocaleString()}</td>
              <td>${row.clicks.toLocaleString()}</td>
              <td>${(row.ctr * 100).toFixed(2)}%</td>
              <td>$${row.cpc.toFixed(2)}</td>
              <td>${row.roas ? row.roas.toFixed(2) + 'x' : '-'}</td>
            </tr>
          `).join('')}
        </tbody>
      </table>
    </div>

    <!-- Footer -->
    <div class="footer">
      ${includeAgencyBranding && agency ? `
        Generated by ${agency.name} • 
      ` : ''}
      ${showWatermark ? `
        <div style="margin-top: 10px; padding: 10px; background: rgba(59, 130, 246, 0.1); border-radius: 8px; border: 1px solid rgba(59, 130, 246, 0.2);">
          <span style="color: #3b82f6; font-weight: 600;">⚡ Powered by AgencyOS AI</span>
          <span style="color: #64748b; margin-left: 10px;">•</span>
          <span style="color: #64748b; margin-left: 10px;">Upgrade to Professional to remove this watermark</span>
        </div>
      ` : `AgencyOS AI • ${new Date().toLocaleDateString()}`}
    </div>
  </div>
</body>
</html>
  `;
}

function generateNext7DaysPlan(analysis: PerformanceAnalysis): string[] {
  const plan = [
    'Review and pause underperforming campaigns identified in this report',
    'Implement top optimization suggestion and monitor results',
    'A/B test new ad creative based on winning patterns',
    'Adjust budget allocation according to recommendations',
    'Monitor key metrics daily and document changes',
    'Scale winning campaigns by 20-30% if performance holds',
    'Prepare next week\'s content calendar based on insights',
  ];
  
  return plan;
}

function generateBudgetAllocation(
  performance_data: AdPerformanceData[],
  analysis: PerformanceAnalysis
): Array<{ campaign: string; current: number; recommended: number; change: number; reason: string }> {
  const totalSpend = performance_data.reduce((sum, d) => sum + d.spend, 0);
  
  return performance_data.slice(0, 5).map(campaign => {
    const currentPercent = (campaign.spend / totalSpend) * 100;
    let recommendedPercent = currentPercent;
    let reason = 'Maintain current budget';
    
    // High ROAS campaigns - increase budget
    if (campaign.roas && campaign.roas > 4) {
      recommendedPercent = currentPercent * 1.3;
      reason = 'High ROAS - scale up';
    }
    // Low ROAS campaigns - decrease budget
    else if (campaign.roas && campaign.roas < 2) {
      recommendedPercent = currentPercent * 0.7;
      reason = 'Low ROAS - reduce spend';
    }
    // High CTR - increase budget
    else if (campaign.ctr > 0.02) {
      recommendedPercent = currentPercent * 1.2;
      reason = 'Strong engagement';
    }
    // Low CTR - decrease budget
    else if (campaign.ctr < 0.01) {
      recommendedPercent = currentPercent * 0.8;
      reason = 'Weak engagement';
    }
    
    const recommended = (recommendedPercent / 100) * totalSpend;
    const change = ((recommended - campaign.spend) / campaign.spend) * 100;
    
    return {
      campaign: campaign.campaign_name.substring(0, 30),
      current: campaign.spend,
      recommended,
      change,
      reason,
    };
  });
}
      font-size: 12px;
      text-transform: uppercase;
    }
    .footer {
      text-align: center;
      margin-top: 40px;
      padding-top: 20px;
      border-top: 1px solid ${theme === 'dark' ? '#334155' : '#e2e8f0'};
      opacity: 0.6;
      font-size: 12px;
    }
  </style>
</head>
<body>
  <div class="header">
    <div>
      ${brand_kit?.logo_url ? `<img src="${brand_kit.logo_url}" class="logo" alt="Logo">` : ''}
      <div class="title">${client.name}</div>
      <div class="subtitle">Performance Report: ${period.start} - ${period.end}</div>
    </div>
  </div>

  <div class="kpi-grid">
    <div class="kpi-card">
      <div class="kpi-label">Total Spend</div>
      <div class="kpi-value">$${totals.spend.toLocaleString('en-US', { minimumFractionDigits: 2 })}</div>
    </div>
    <div class="kpi-card">
      <div class="kpi-label">Avg CTR</div>
      <div class="kpi-value">${(avgCTR * 100).toFixed(2)}%</div>
    </div>
    <div class="kpi-card">
      <div class="kpi-label">Avg CPC</div>
      <div class="kpi-value">$${avgCPC.toFixed(2)}</div>
    </div>
    <div class="kpi-card">
      <div class="kpi-label">ROAS</div>
      <div class="kpi-value">${avgROAS.toFixed(2)}x</div>
    </div>
  </div>

  ${analysis.industry_comparison ? `
  <div class="section">
    <div class="section-title">Industry Benchmark Comparison</div>
    <ul class="insight-list">
      <li class="insight-item">
        <span class="insight-icon">📊</span>
        <strong>CTR:</strong> ${analysis.industry_comparison.ctr_vs_industry}
      </li>
      <li class="insight-item">
        <span class="insight-icon">💰</span>
        <strong>CPC:</strong> ${analysis.industry_comparison.cpc_vs_industry}
      </li>
      <li class="insight-item">
        <span class="insight-icon">📈</span>
        <strong>ROAS:</strong> ${analysis.industry_comparison.roas_vs_industry}
      </li>
    </ul>
  </div>
  ` : ''}

  <div class="section">
    <div class="section-title">✅ What Worked</div>
    <ul class="insight-list">
      ${analysis.what_worked.map(item => `
        <li class="insight-item positive">
          <span class="insight-icon">✓</span>${item}
        </li>
      `).join('')}
    </ul>
  </div>

  <div class="section">
    <div class="section-title">⚠️ What Underperformed</div>
    <ul class="insight-list">
      ${analysis.what_underperformed.map(item => `
        <li class="insight-item negative">
          <span class="insight-icon">✗</span>${item}
        </li>
      `).join('')}
    </ul>
  </div>

  <div class="section">
    <div class="section-title">💡 Optimization Suggestions</div>
    <ul class="insight-list">
      ${analysis.optimization_suggestions.map(item => `
        <li class="insight-item neutral">
          <span class="insight-icon">→</span>${item}
        </li>
      `).join('')}
    </ul>
  </div>

  <div class="section">
    <div class="section-title">Campaign Performance Details</div>
    <table>
      <thead>
        <tr>
          <th>Campaign</th>
          <th>Spend</th>
          <th>Impressions</th>
          <th>Clicks</th>
          <th>CTR</th>
          <th>CPC</th>
          <th>ROAS</th>
        </tr>
      </thead>
      <tbody>
        ${performance_data.map(row => `
          <tr>
            <td>${row.campaign_name}</td>
            <td>$${row.spend.toFixed(2)}</td>
            <td>${row.impressions.toLocaleString()}</td>
            <td>${row.clicks.toLocaleString()}</td>
            <td>${(row.ctr * 100).toFixed(2)}%</td>
            <td>$${row.cpc.toFixed(2)}</td>
            <td>${row.roas ? row.roas.toFixed(2) + 'x' : '-'}</td>
          </tr>
        `).join('')}
      </tbody>
    </table>
  </div>

  <div class="footer">
    Generated by AgencyOS AI • ${new Date().toLocaleDateString()}
  </div>
</body>
</html>
  `;
}

